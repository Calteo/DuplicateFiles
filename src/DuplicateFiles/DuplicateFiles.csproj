  <ItemGroup>
    <PackageReference Include="Toolbox.CommandLine" Version="1.1.13" />
    <PackageReference Include="Toolbox.Core" Version="0.6.21" />
    <PackageReference Include="Toolbox.Forms" Version="0.2.10" />
  </ItemGroup>

</Project>